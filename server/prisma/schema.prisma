// prisma/schema.prisma
generator client {
  provider = "prisma-client" // Note: In v7, 'prisma-client' is common
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Employer {
  id                String   @id @default(uuid())
  companyName       String
  gstNumber         String   @unique
  isVerified        Boolean  @default(false) // The "Blue Tick"
  trustScore        Int      @default(100)   // Starts at 100
  responseRate      Float    @default(100.0)
  jobs              Job[]
}

model Job {
  id                String   @id @default(uuid())
  title             String
  description       String
  postedAt          DateTime @default(now())
  slaDeadline       Int      @default(72)    // 72-hour requirement
  employer          Employer @relation(fields: [employerId], references: [id])
  employerId        String
  applications      Application[]
}

model Application {
  id                String   @id @default(uuid())
  candidateName     String
  status            String   @default("Applied") // Applied -> AI Screened -> Interview
  appliedAt         DateTime @default(now())
  lastUpdatedAt     DateTime @updatedAt
  job               Job      @relation(fields: [jobId], references: [id])
  jobId             String
}